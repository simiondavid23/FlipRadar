# FlipRadar — exemplu de configurare .env (copiază în .env și completează)

# ── Optionale (au default-uri — aplicatia porneste si fara .env) ──
# DATABASE_URL — daca lipseste, baza merge automat in directorul de date al
# instantei (in dev = cwd, adica ./flipradar.db). Decomenteaza doar ca sa
# tintesti explicit alt DB.
# DATABASE_URL=sqlite:///./flipradar.db
# alternativ (PostgreSQL): DATABASE_URL=postgresql://postgres:parola@localhost:5432/flipradar
# SECRET_KEY — daca lipseste, se autogenereaza (token_hex(32) = 64 caractere) si
# persista in <data_dir>/secret_key, deci sesiunile supravietuiesc restarturilor.
# Seteaz-o manual doar daca vrei o cheie fixa (min 32 caractere).
# SECRET_KEY=schimba_aceasta_cheie_minim_32_caractere
GROQ_API_KEY=gsk_...
ALGORITHM=HS256

# ── SMTP (opțional) — alerte pe email ─────────────────────────
SMTP_HOST=mail.exemplu.com
SMTP_PORT=587
SMTP_USER=utilizator
SMTP_PASSWORD=parola
SMTP_FROM=no-reply@flipradar.local
SMTP_USE_TLS=true

# ── Proxy (opțional) pentru scrapere ──────────────────────────
PROXY_ENABLED=false
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=

# ── Web Push (VAPID) ──────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=flipradar@exemplu.ro

# ── Criptare cookies grupuri Facebook ─────────────────────────
COOKIE_ENCRYPTION_KEY=

# ── Facebook re-autentificare automată (MODIFICARE 11) ────────
FACEBOOK_EMAIL=email@exemplu.com
FACEBOOK_PASSWORD=parola_facebook

# ── Logs persistente în DB (MODIFICARE 12, opțional) ──────────
LOG_DB_PERSISTENCE=false
